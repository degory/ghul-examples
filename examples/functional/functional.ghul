use IO.Std.write_line;
use Collections.LIST;

use Ghul.Pipes.STREAM;
use Ghul.Pipes.stream;
use Ghul.Pipes.pipe;

use STREAM.DONE;
use STREAM.YIELD;

entry() is
    first_class_functions();
    map_filter_reduce_examples();
    expression_body_example(3, 4);
    pure_examples();
    self_recursion_examples();
    mutual_recursion_by_argument();
    mutual_recursion_by_forward_reference();
    immutable_data_structures_and_pure_functions();
    higher_order_functions_examples();
    custom_operator();
    if_and_case_expressions();
    union_examples();
    currying_examples();
    partial_application_examples();
    stream_examples();
si

first_class_functions() is
    let f = i => i * 2;

    let g = f;

    write_line("g(123) is {g(123)}");
si

// map filter reduce
map_filter_reduce_examples() is
    // see pipes examples for more details

    // map
    let doubled = [1, 2, 3, 4, 5] | .map(x => x * 2);
    write_line("doubled: {doubled}");
 
    // filter
    let evens = [1, 2, 3, 4, 5] | .filter(x => x % 2 == 0);
    write_line("evens: {evens}");

    // reduce
    let sum = [1, 2, 3, 4, 5] | .reduce(0, (acc, x) => acc + x);
    write_line("sum: {sum}");
si

// expression bodied functions and let-in
expression_body_example(a: int, b: int) -> string =>
    let sum = a + b in
    if sum > 10 then
        "{sum} > 10"
    else
        "{sum} <= 10"
    fi;

// Expression bodied functions and some support for
// expression oriented programming help in writing
// pure functions
pure_examples() is
    let list = [1, 2, 3, 4, 5];

    // lists can be subscripted to read an element at a given index
    let element_3 = list[3];

    // but lists are immutable, so this will cause a compile time
    // error if uncommented:
    // list[3] = 10;

    let tuple = (1, 2, 3, 4, 5);

    // tuples can be destructured
    let (a, b, c, d, e) = tuple;

    // individual members can be accessed with dot notation
    let first = tuple.`1;

    // but tuples are immutable, so members cannot be assigned to:
    // tuple.`1 = 10; // compile time error

    let classify = n =>
        if n == 0 then
            "Zero"
        elif n % 2 == 0 /\ n < 0 then
            if n % 5 == 0 then "Negative even and multiple of 5"
            else "Negative even" fi
        elif n % 2 != 0 /\ n < 0 then
            if n % 5 == 0 then "Negative odd and multiple of 5"
            else "Negative odd" fi
        elif n % 2 == 0 then
            if n % 5 == 0 then "Positive even and multiple of 5"
            else "Positive even" fi
        else
            if n % 5 == 0 then "Positive odd and multiple of 5"
            else "Positive odd" fi
        fi;

    write_line("classifyNumber(-10): {classify(-10)}");
    write_line("classifyNumber(-3): {classify(-3)}");
    write_line("classifyNumber(0): {classify(0)}");
    write_line("classifyNumber(4): {classify(4)}");
    write_line("classifyNumber(25): {classify(25)}");
si

// self recursion with anonymous functions:
self_recursion_examples() is
    // factorial
    let factorial = 
        n rec => 
            if n == 0 then
                1 
            else 
                n * rec(n - 1)
            fi;

    write_line("factorial(5): {factorial(5)}");
 
    // fibonacci
    let fibonacci = 
        n rec => 
            if n <= 1 then
                n 
            else 
                rec(n - 1) + rec(n - 2)
            fi;

    write_line("fibonacci(5): {fibonacci(5)}");
si

// mutual recursion is slightly awkward for anonymous functions because
// of the forward reference. one way is to pass the other function in as
// an argument:
mutual_recursion_by_argument() is
    let is_even = (n, is_odd) => if n == 0 then true else is_odd(n - 1) fi;
    let is_odd = n rec => if n == 0 then false else is_even(n - 1, rec) fi;

    write_line("even(10): {is_even(10, is_odd)}");
    write_line("odd(10): {is_odd(10)}");
si

// another way is to declare one of the functions as a mutable variable
// and assign the anonymous function to it after the other is defined:
mutual_recursion_by_forward_reference() is
    let is_odd mut = default;

    let is_even = n => if n == 0 then true else is_odd(n - 1) fi;
    is_odd = n => if n == 0 then false else is_even(n - 1) fi;

    write_line("even(10): {is_even(10)}");
    write_line("odd(10): {is_odd(10)}");
si

// mutual recursion with named functions, doesn't require any workarounds:
is_even(n: int) -> bool => if n == 0 then true else is_odd(n - 1) fi;
is_odd(n: int) -> bool => if n == 0 then false else is_even(n - 1) fi;

// immutable data structures and pure functions
immutable_data_structures_and_pure_functions() is
    // immutable data structures
    let list = [1, 2, 3, 4, 5];

    let doubled = list | .map(x => x * 2);

    // original list is still the same:
    write_line("list: {list | }");

    // pure functions
    let add = (x, y) => x + y;
    write_line("add(5, 3): {add(5, 3)}");
si

// higher-order functions:

// higher-order generically typed global functions:
apply[T](f: T -> T, x: T) -> T =>
    f(x);

apply_if[T](f: T -> T, x: T, predicate: T -> bool) -> T =>
    if predicate(x) then f(x) else x fi;

// higher-order generically typed methods:
class HIGHER_ORDER_FUNCTIONS[T] is
    apply(f: T -> T, x: T) -> T static =>
        f(x);

    apply_if(f: T -> T, x: T, predicate: T -> bool) -> T static =>
        if predicate(x) then f(x) else x fi;
si

// higher order non-genericly typed anonymous functions:
higher_order_functions_examples() is
    let times_2 = x => x * 2;
    write_line("apply(times_2, 5): {apply(times_2, 5)}");

    let square = x => x * x;
    write_line("apply(square, 5): {apply(square, 5)}");

    // higher order function consumes another function:
    let apply_twice = (f, x) => f(f(x));
    write_line("apply_twice(times_2, 5): {apply_twice(times_2, 5)}");

    // higher order function returns another function:
    let create_apply_twice = f => x => f(f(x));
    let apply_twice_times_2 = create_apply_twice(times_2);

    write_line("apply_twice_times_2(5): {apply_twice_times_2(5)}");
si

// define a custom operator
>>[A, B, C](f: A -> B, g: B -> C) -> A -> C =>
    x => g(f(x));

custom_operator() is
    let times_2 = x => x * 2;
    let add_1 = x => x + 1;

    // use our new >> operator to compose functions:
    let times_2_then_add_1 = times_2 >> add_1;
    write_line("times_2_then_add_1(5): {times_2_then_add_1(5)}");

    let pipeline = times_2 >> add_1 >> x => "[{x}]";
    write_line("pipeline(5): {pipeline(5)}");
si

// if and case expressions
if_and_case_expressions() is
    // an if-then-else-fi can stand in expression position: both
    // branches produce a value, and the result type is whatever type
    // is compatible with both:
    let parity =
        n =>
            if n % 2 == 0 then
                "even"
            else
                "odd"
            fi;

    write_line("parity(10): {parity(10)}");
    write_line("parity(11): {parity(11)}");

    // case does the same job and reads cleaner with more arms. an
    // arm can match several values at once. an expression-position
    // case requires an else arm:
    let describe =
        n =>
            case n
            when -1 then "minus one"
            when 0 then "zero"
            when 1 then "one"
            when 2 then "two"
            when 6, 7, 8 then "small"
            when 13 then "unlucky"
            else "other"
            esac;

    write_line("describe(-1): {describe(-1)}");
    write_line("describe(2): {describe(2)}");
    write_line("describe(7): {describe(7)}");
    write_line("describe(42): {describe(42)}");
si

// unions
union_examples() is
    option_example();

    write_line(list_example([1, 2, 3]));
    write_line(list_example(["A", "B", "C"]));
    write_line(tree_example([1, 2, 3, 4]));
    write_line(tree_example(["A", "B", "C", "D"]));
si

union Option[T] is
    NONE;
    SOME(value: T);
si

union List[T] is
    NIL;
    CONS(head: T, tail: List[T]);
si

union Tree[T] is
    LEAF(value: T);
    NODE(left: Tree[T], right: Tree[T]);
si

use Option.SOME;
use Option.NONE;
use List.NIL;
use List.CONS;
use Tree.LEAF;
use Tree.NODE;

option_example() is
    let some_int = SOME(42);
    let none_int = NONE;

    // isa SOME(o) tests the variant and narrows o to it, so o.value is reachable
    let stringify_option = o rec =>
        if isa SOME(o) then
            "{o.value}"
        else
            "none"
        fi;

    write_line(stringify_option(some_int));
    write_line(stringify_option(none_int));
si

list_example[T](elements: Collections.List[T]) -> string =>
    assert elements.count == 3 else "expected 3 elements" in

    let
        list = CONS(elements[0], CONS(elements[1], CONS(elements[2], NIL))),
        stringify_list = l rec =>
            if let (head, tail): CONS = l then
                "{head}, {rec(tail)}"
            else
                "nil"
            fi
    in
        stringify_list(list);

tree_example[T](leaves: Collections.List[T]) -> string =>
    assert leaves.count == 4 else "expected 4 leaves" in

    let tree = 
        NODE(
            NODE(
                LEAF(leaves[0]),
                LEAF(leaves[1])
            ),
            NODE(
                LEAF(leaves[2]),
                LEAF(leaves[3])
            )
        )
    in

    let stringify_tree = t rec =>
        if let (left, right): NODE = t then
            // if it's a NODE, recursively stringify the
            // left and right subtrees
            "({rec(left)}, {rec(right)})"
        else
            // if it's not a NODE, it must be a LEAF, so
            // just stringify the value
            "{t.value}"
        fi
    in

    stringify_tree(tree);


next[T](iterator: Collections.Iterator[T]) -> Option[T] =>
    if iterator.move_next() then
        SOME(iterator.current)
    else
        NONE
    fi;


// currying
currying_examples() is
    let curried_add = x => y => x + y;
    write_line("curried_add(5)(3): {curried_add(5)(3)}");

    let add_5 = curried_add(5);
    write_line("add_5(3): {add_5(3)}");

    let add_10 = curried_add(10);
    write_line("add_10(3): {add_10(3)}");
si

// partial application
partial_application_examples() is
    let add = (x, y) => x + y;

    let add_5 = y => add(5, y);
    write_line("add_5(3): {add_5(3)}");

    let add_10 = y => add(10, y);
    write_line("add_10(3): {add_10(3)}");
si

// stream(initial, advance) builds a lazy Pipe[T] from a start state and
// a step function S -> STREAM[T, S]. The step returns DONE to stop, or
// value || next_state to yield the next value.

stream_examples() is
    // count down from n to 1:
    let counting = n =>
        stream(n, i => if i == 0 then DONE else i || (i - 1) fi);

    // infinite fibonacci. State is (prev, current); output is the
    // current value - state and output types are different.
    let fibonacci = stream(
        (prev = 1, current = 1),
        s => s.current || (prev = s.current, current = s.prev + s.current)
    );

    // factorial. State is (n, prev); output is int.

    let factorial = stream(
        (n = 1, prev = 1),
        s => let next_n = s.n + 1, next = s.prev * next_n in
            next || (n = next_n, prev = next)
    );

    // chars-of-a-string: state is an int index, output is char.
    // the canonical "state type differs from output type" example -
    // input is closed over by the anonymous function, integer state is hidden
    // inside the resulting Pipe[char].

    let chars_of = s =>
        let xs = s.to_char_array() in
        stream(0, i => if i == xs.count then DONE else xs[i] || (i + 1) fi);

    write_line("counting down from 5: {counting(5)}");
    write_line("chars of hello: {chars_of("hello")}");

    write_line("first 10 fibonacci numbers: {fibonacci | .take(10)}");
    write_line("first 10 factorial numbers: {factorial | .take(10)}");
    write_line("first 10 even fibonacci numbers: {fibonacci | .filter(x => x % 2 == 0) .take(10)}");

    for (i, (fib, fact)) in fibonacci | .zip(factorial) .take(10) .index() do
        write_line("fibonacci {i} is {fib}");
        write_line("factorial {i} is {fact}");
    od;
si
